# Postgres
POSTGRES_DB=example_db
POSTGRES_USER=example_user
POSTGRES_PASSWORD=example_password

# Common
DATABASE_URL=example_database_url
REDIS_URL=example_redis_url

# Auth
JWT_SECRET=example-jwt-secret-change-in-production
RUST_LOG=blog_auth_api=debug,tower_http=debug,info
FRONTEND_URL=example-frontend-url
