# OAuth Providers (uncomment and fill in to enable)
GOOGLE_CLIENT_ID=example-google-client-id
GOOGLE_CLIENT_SECRET=example-google-client-secret
GITHUB_CLIENT_ID=example-github-client-id
GITHUB_CLIENT_SECRET=example-github-client-secret
APPLE_CLIENT_ID=example-apple-client-id
APPLE_CLIENT_SECRET=example-apple-client-secret
LINE_CLIENT_ID=example-line-client-id
LINE_CLIENT_SECRET=example-line-client-secret
KAKAO_CLIENT_ID=example-kakao-client-id
KAKAO_CLIENT_SECRET=example-kakao-client-secret